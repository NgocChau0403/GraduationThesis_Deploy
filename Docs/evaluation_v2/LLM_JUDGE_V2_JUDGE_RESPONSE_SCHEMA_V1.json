{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "LLM_JUDGE_V2_JUDGE_RESPONSE_SCHEMA_V1.json",
  "title": "LLM Judge V2 Direct Judge Response",
  "description": "Direct Codex judge response before runner-derived scoring, caps, verdict, and execution provenance are added.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_id",
    "scoring_status",
    "subscores",
    "claim_checks",
    "errors",
    "holistic_rationale",
    "evidence_usage_notes"
  ],
  "properties": {
    "schema_version": {
      "const": "judge_response_schema_v1"
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "scoring_status": {
      "enum": [
        "scored",
        "invalid"
      ]
    },
    "subscores": {
      "oneOf": [
        {
          "$ref": "#/$defs/subscores"
        },
        {
          "type": "null"
        }
      ]
    },
    "claim_checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim_check"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/error_record"
      }
    },
    "holistic_rationale": {
      "type": "string"
    },
    "evidence_usage_notes": {
      "type": "string"
    },
    "invalid_reason": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "scoring_status": {
            "const": "scored"
          }
        },
        "required": [
          "scoring_status"
        ]
      },
      "then": {
        "properties": {
          "subscores": {
            "$ref": "#/$defs/subscores"
          },
          "invalid_reason": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "scoring_status": {
            "const": "invalid"
          }
        },
        "required": [
          "scoring_status"
        ]
      },
      "then": {
        "required": [
          "invalid_reason"
        ],
        "properties": {
          "subscores": {
            "const": null
          },
          "claim_checks": {
            "maxItems": 0
          },
          "errors": {
            "maxItems": 0
          },
          "invalid_reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  ],
  "$defs": {
    "metric_name": {
      "enum": [
        "faithfulness",
        "numerical_correctness",
        "completeness",
        "task_relevance",
        "actionability",
        "clarity",
        "safety_fairness"
      ]
    },
    "severity": {
      "enum": [
        "minor",
        "major",
        "critical"
      ]
    },
    "subscores": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "faithfulness",
        "numerical_correctness",
        "completeness",
        "task_relevance",
        "actionability",
        "clarity",
        "safety_fairness"
      ],
      "properties": {
        "faithfulness": {
          "$ref": "#/$defs/metric_score"
        },
        "numerical_correctness": {
          "$ref": "#/$defs/metric_score"
        },
        "completeness": {
          "$ref": "#/$defs/metric_score"
        },
        "task_relevance": {
          "$ref": "#/$defs/metric_score"
        },
        "actionability": {
          "$ref": "#/$defs/metric_score"
        },
        "clarity": {
          "$ref": "#/$defs/metric_score"
        },
        "safety_fairness": {
          "$ref": "#/$defs/metric_score"
        }
      }
    },
    "metric_score": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applicability",
        "score",
        "rationale"
      ],
      "properties": {
        "applicability": {
          "enum": [
            "applicable",
            "not_applicable"
          ]
        },
        "score": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1,
          "maximum": 10
        },
        "rationale": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "applicability": {
                "const": "applicable"
              }
            },
            "required": [
              "applicability"
            ]
          },
          "then": {
            "properties": {
              "score": {
                "type": "integer",
                "minimum": 1,
                "maximum": 10
              }
            }
          },
          "else": {
            "properties": {
              "score": {
                "const": null
              }
            }
          }
        }
      ]
    },
    "claim_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "claim_text",
        "claim_type",
        "claim_scope",
        "support_status",
        "evidence_refs",
        "checker_source",
        "rationale"
      ],
      "properties": {
        "claim_id": {
          "type": "string",
          "pattern": "^C[0-9]+$"
        },
        "claim_text": {
          "type": "string",
          "minLength": 1
        },
        "claim_type": {
          "type": "string",
          "minLength": 1
        },
        "claim_scope": {
          "enum": [
            "core",
            "supporting",
            "incidental"
          ]
        },
        "support_status": {
          "enum": [
            "supported",
            "partially_supported",
            "unsupported",
            "contradicted",
            "not_verifiable"
          ]
        },
        "impact_type": {
          "enum": [
            "local_detail",
            "weakens_support",
            "changes_interpretation",
            "reverses_main_finding",
            "wrong_evaluation_target"
          ]
        },
        "evidence_refs": {
          "$ref": "#/$defs/string_array"
        },
        "expected_value": {},
        "observed_value": {},
        "checker_source": {
          "enum": [
            "deterministic_checker",
            "llm_judge",
            "hybrid"
          ]
        },
        "checker_details": {
          "type": "object",
          "additionalProperties": true
        },
        "rationale": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "support_status": {
                "const": "supported"
              }
            },
            "required": [
              "support_status"
            ]
          },
          "else": {
            "required": [
              "impact_type"
            ]
          }
        }
      ]
    },
    "error_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "error_id",
        "error_type",
        "claim_ids",
        "severity",
        "primary_metric",
        "secondary_metrics",
        "cap_candidate",
        "rationale",
        "evidence_refs"
      ],
      "properties": {
        "error_id": {
          "type": "string",
          "pattern": "^E[0-9]+$"
        },
        "error_type": {
          "type": "string",
          "minLength": 1
        },
        "claim_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^C[0-9]+$"
          },
          "uniqueItems": true
        },
        "requirement_id": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "primary_metric": {
          "$ref": "#/$defs/metric_name"
        },
        "secondary_metrics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/metric_name"
          },
          "uniqueItems": true
        },
        "cap_candidate": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 1,
          "maximum": 10
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": {
          "$ref": "#/$defs/string_array"
        }
      }
    },
    "string_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
