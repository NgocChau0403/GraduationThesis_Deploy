datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ============================================================
// NORMALIZED RELATIONAL SCHEMA — ERD v2.3
// Decisions applied:
//   - has_romantic / has_extracurricular / has_paid_class (diagram naming)
//   - withdrew_early: Boolean (fixed from Int in old flat schema)
//   - engagement.log_click_score (renamed from engagement_score to avoid collision with enrollment_features.engagement_score)
//   - Flat tables kept for dashboard backward compatibility
// ============================================================

// -------------------------------------------------------
// 1. STUDENT
// -------------------------------------------------------
model Student {
  student_id     String @id
  batch_id       String
  source_dataset String

  // Demographic
  gender         String?
  age_years      Int?
  age_group      String?
  region         String?
  residence_area String?

  // UCI-specific demographic
  school      String?
  family_size String?

  // Academic background
  highest_education String?

  // Socioeconomic
  socioeconomic_band String?
  imd_score_numeric  Float?
  disability_flag    Boolean?

  // Intent & Support flags
  higher_education_intent_flag Boolean?
  internet_access_flag         Boolean?
  school_support_flag          Boolean?
  family_support_flag          Boolean?

  // Family background (UCI-sourced)
  mother_education_level     String?
  father_education_level     String?
  mother_job                 String?
  father_job                 String?
  guardian_type              String?
  parent_cohabitation_status String?

  // Lifestyle & behavior (UCI-sourced)
  travel_time         Int?
  free_time           Int?
  go_out_freq         Int?
  alcohol_weekday     Int?
  alcohol_weekend     Int?
  health_status       Int?
  family_relation     Int?
  has_romantic        Boolean?
  has_extracurricular Boolean?
  has_paid_class      Boolean?

  created_at DateTime  @default(now())
  updated_at DateTime?

  // Relations
  batch               ImportBatch          @relation(fields: [batch_id], references: [batch_id], onDelete: Cascade)
  enrollments         Enrollment[]
  exam_results        ExamResult[]
  engagements         Engagement[]

  @@index([batch_id])
  @@index([source_dataset])
  @@map("student")
}

// -------------------------------------------------------
// 2. COURSE
// -------------------------------------------------------
model Course {
  course_id      String @id
  batch_id       String
  source_dataset String

  course_name  String?
  subject_area String?

  created_at DateTime @default(now())

  // Relations
  batch   ImportBatch @relation(fields: [batch_id], references: [batch_id], onDelete: Cascade)
  classes Class[]

  @@index([batch_id])
  @@map("course")
}

// -------------------------------------------------------
// 3. CLASS
// -------------------------------------------------------
model Class {
  class_id       String @id
  batch_id       String
  course_id      String
  source_dataset String

  class_run     String?
  semester      String?
  academic_year String?

  // OULAD: module_presentation_length. NULL for UCI.
  duration_days Int?

  delivery_mode String?
  platform      String?

  created_at DateTime  @default(now())
  updated_at DateTime?

  // Relations
  batch               ImportBatch          @relation(fields: [batch_id], references: [batch_id], onDelete: Cascade)
  course              Course               @relation(fields: [course_id], references: [course_id])
  enrollments         Enrollment[]
  assessments         Assessment[]
  events              Event[]

  @@index([batch_id])
  @@index([course_id])
  @@unique([batch_id, course_id, class_run])
  @@map("class")
}

// -------------------------------------------------------
// 4. ENROLLMENT
// -------------------------------------------------------
model Enrollment {
  enrollment_id  String @id
  batch_id       String
  student_id     String
  class_id       String
  source_dataset String

  // INT offset (raw from OULAD). NULL for UCI.
  enrollment_start_day Int?
  enrollment_end_day   Int?

  final_outcome          String?
  previous_attempt_count Int?
  study_load_credits     Int?

  // UCI raw behavioral fields (per enrollment context)
  absences  Int?
  studytime Int?

  created_at DateTime @default(now())

  // Relations
  batch               ImportBatch          @relation(fields: [batch_id], references: [batch_id], onDelete: Cascade)
  student             Student              @relation(fields: [student_id], references: [student_id])
  class               Class                @relation(fields: [class_id], references: [class_id])
  exam_results        ExamResult[]
  engagements         Engagement[]
  enrollment_features EnrollmentFeatures[]

  @@index([batch_id])
  @@index([student_id])
  @@index([class_id])
  @@index([student_id, class_id, source_dataset])
  @@unique([batch_id, student_id, class_id])
  @@map("enrollment")
}

// -------------------------------------------------------
// 5. ASSESSMENT
// -------------------------------------------------------
model Assessment {
  assessment_id  String @id
  batch_id       String
  class_id       String
  source_dataset String

  assessment_name  String?
  assessment_type  String?
  assessment_order Int?

  // INT offset (raw from OULAD). NULL for UCI.
  due_day Int?

  weight_pct          Float?
  is_final_assessment Boolean?

  // Single dominant competency tag for this assessment.
  // If multi-competency support is needed later, split to a bridge table.
  competency_tag String?

  // Computed: due_day / 7
  week_of_class Int?

  created_at DateTime  @default(now())
  updated_at DateTime?

  // Relations
  batch        ImportBatch @relation(fields: [batch_id], references: [batch_id], onDelete: Cascade)
  class        Class        @relation(fields: [class_id], references: [class_id])
  exam_results ExamResult[]

  @@index([batch_id])
  @@index([class_id])
  @@unique([batch_id, class_id, assessment_order])
  @@map("assessment")
}

// -------------------------------------------------------
// 6. EXAM_RESULT
// -------------------------------------------------------
model ExamResult {
  result_id      String @id
  batch_id       String
  assessment_id  String
  student_id     String
  enrollment_id  String
  source_dataset String

  // score_raw: original score preserved for audit (UCI: 0-20, OULAD: 0-100)
  score_raw        Float?
  score_normalized Float?
  pass_flag        Boolean?

  // INT offset (raw from OULAD). NULL for UCI.
  submission_day        Int?
  submission_delay_days Int? // Positive = late, Negative = early

  is_banked Boolean?

  created_at DateTime @default(now())

  // Relations
  batch      ImportBatch @relation(fields: [batch_id], references: [batch_id], onDelete: Cascade)
  assessment Assessment @relation(fields: [assessment_id], references: [assessment_id])
  student    Student    @relation(fields: [student_id], references: [student_id])
  enrollment Enrollment @relation(fields: [enrollment_id], references: [enrollment_id])

  @@index([batch_id])
  @@index([assessment_id])
  @@index([student_id])
  @@index([enrollment_id])
  @@index([student_id, source_dataset])
  @@unique([batch_id, enrollment_id, assessment_id])
  @@map("exam_result")
}

// -------------------------------------------------------
// 7. EVENT
// -------------------------------------------------------
model Event {
  event_id       String @id
  batch_id       String
  class_id       String
  source_dataset String

  resource_id   String?
  resource_type String?

  // OULAD: mapped from week_from/week_to. NULL for UCI.
  available_from_week Int?
  available_to_week   Int?

  created_at DateTime @default(now())

  // Relations
  batch       ImportBatch   @relation(fields: [batch_id], references: [batch_id], onDelete: Cascade)
  class       Class        @relation(fields: [class_id], references: [class_id])
  engagements Engagement[]

  @@index([batch_id])
  @@index([class_id])
  @@unique([batch_id, class_id, resource_id])
  @@map("event")
}

// -------------------------------------------------------
// 8. ENGAGEMENT
// [F7] class_id removed — reachable via enrollment_id → enrollment.class_id
// -------------------------------------------------------
model Engagement {
  engagement_id String @id
  batch_id      String
  event_id      String
  student_id    String
  enrollment_id String
  source_dataset String

  // INT offset (raw from OULAD). NULL for UCI.
  event_day   Int?
  week_number Int?

  engagement_count Int?   // OULAD: sum_click
  log_click_score  Float? // Row-level: log(engagement_count + 1). Renamed from engagement_score to avoid collision with enrollment_features.engagement_score

  created_at DateTime @default(now())

  // Relations
  batch      ImportBatch @relation(fields: [batch_id], references: [batch_id], onDelete: Cascade)
  event      Event      @relation(fields: [event_id], references: [event_id])
  student    Student    @relation(fields: [student_id], references: [student_id])
  enrollment Enrollment @relation(fields: [enrollment_id], references: [enrollment_id])

  @@index([batch_id])
  @@index([event_id])
  @@index([student_id])
  @@index([enrollment_id])
  @@index([week_number])
  @@unique([batch_id, student_id, event_id, event_day])
  @@map("engagement")
}

// -------------------------------------------------------
// 9. ENROLLMENT_FEATURES (Feature Store)
// Grain: 1 row = 1 enrollment
// Computed cache for ML models & dashboard — not raw data
// -------------------------------------------------------
model EnrollmentFeatures {
  ef_id          String   @id
  batch_id       String
  enrollment_id  String
  computed_at    DateTime
  source_dataset String

  // --- Background profile snapshot ---
  lifestyle_risk_score   Float?
  support_score          Float?
  social_balance_score   Float?
  family_stability_score Float?
  disadvantage_score     Float?

  // --- Score metrics ---
  avg_score         Float?
  performance_trend Float?
  score_consistency Float?
  pass_rate         Float?

  // --- Engagement metrics ---
  // NOTE: engagement_score here is aggregated composite — distinct from engagement.log_click_score
  total_engagement_count   Int?
  active_day_count         Int?
  study_effort_level       String?
  engagement_score         Float?
  consistency_level        String?
  vle_diversity_score      Float?
  forum_engagement_rate    Float?
  quiz_engagement_rate     Float?
  resource_engagement_rate Float?
  weekly_engagement_drop   Float?

  // --- Risk / warning signals ---
  early_warning_week     Int?
  absences_rate          Float?
  punctuality_rate       Float?
  submission_delay_avg   Float?
  registration_lead_time Int?
  withdrew_early         Boolean? // Fixed: was Int in old flat schema

  // --- Final risk label ---
  at_risk_score Int?
  at_risk_label String?

  // Relations
  batch      ImportBatch @relation(fields: [batch_id], references: [batch_id], onDelete: Cascade)
  enrollment Enrollment  @relation(fields: [enrollment_id], references: [enrollment_id])

  @@index([batch_id])
  @@index([enrollment_id])
  @@unique([enrollment_id])
  @@map("enrollment_features")
}

// ============================================================
// FLAT TABLES — Kept for dashboard backward compatibility
// ETL pipeline writes to both normalized + flat tables
// These are denormalized read-optimized views for BI queries
// ============================================================

model FlatEnrollmentMaster {
  id              BigInt @id @default(autoincrement())
  import_batch_id String

  student_id     String
  course_id      String
  source_dataset String

  // Demographic
  gender             String?
  age_group          String?
  region             String?
  residence_area     String?
  highest_education  String?
  socioeconomic_band String?
  imd_score_numeric  Float?
  disability_flag    Boolean?

  // Support flags
  higher_education_intent_flag Boolean?
  internet_access_flag         Boolean?
  school_support_flag          Boolean?
  family_support_flag          Boolean?
  has_romantic                 Boolean?
  has_extracurricular          Boolean?
  has_paid_class               Boolean?

  // Family / lifestyle
  mother_education_level     String?
  father_education_level     String?
  mother_job                 String?
  father_job                 String?
  guardian_type              String?
  family_relation            Int?
  travel_time                Int?
  free_time                  Int?
  go_out_freq                Int?
  alcohol_weekday            Int?
  alcohol_weekend            Int?
  health_status              Int?
  parent_cohabitation_status String?

  // Course context
  course_name          String?
  subject_area         String?
  course_run           String?
  course_duration_days Int?
  study_load_credits   Int?

  // Outcome / enrollment
  final_outcome          String?
  previous_attempt_count Int?
  enrollment_start_day   Int?
  enrollment_end_day     Int?

  // Engagement summary
  total_engagement_count Int?
  active_day_count       Int?
  absence_count          Int?
  study_effort_level     String?
  consistency_level      String?

  // Performance features
  avg_score         Float?
  performance_trend Float?
  score_consistency Float?

  // Engagement features
  absences_rate            Float?
  punctuality_rate         Float?
  engagement_score         Float?
  vle_diversity_score      Float?
  forum_engagement_rate    Float?
  quiz_engagement_rate     Float?
  resource_engagement_rate Float?
  weekly_engagement_drop   Float?
  early_warning_week       Int?

  // Timeliness features
  submission_delay_avg   Float?
  registration_lead_time Int?
  withdrew_early         Boolean? // Fixed: was Int

  // At-risk features
  at_risk_score Int?
  at_risk_label String?

  // Lifestyle features
  lifestyle_risk_score   Float?
  support_score          Float?
  social_balance_score   Float?
  family_stability_score Float?

  // Socioeconomic features
  disadvantage_score Float?

  created_at DateTime @default(now())

  batch ImportBatch @relation(fields: [import_batch_id], references: [batch_id], onDelete: Cascade)

  @@index([import_batch_id])
  @@index([student_id, course_id, source_dataset])
  @@map("flat_enrollment_master")
}

model FlatAssessmentResult {
  id              BigInt @id @default(autoincrement())
  import_batch_id String

  assessment_result_id String?
  student_id           String
  course_id            String
  assessment_order     Int?
  source_dataset       String

  // Assessment identity
  assessment_id         String?
  assessment_name       String?
  assessment_type       String?
  assessment_due_day    Int?
  assessment_weight_pct Float?
  is_final_assessment   Boolean?
  is_banked             Boolean?

  // Assessment values
  score_normalized      Float?
  submission_day        Int?
  submission_delay_days Int?
  pass_flag             Boolean?

  // Student / outcome context
  final_outcome String?
  gender        String?
  age_group     String?

  // Course context
  course_name  String?
  course_run   String?
  subject_area String?

  created_at DateTime @default(now())

  batch ImportBatch @relation(fields: [import_batch_id], references: [batch_id], onDelete: Cascade)

  @@index([import_batch_id])
  @@index([student_id, course_id, source_dataset])
  @@index([assessment_id])
  @@map("flat_assessment_result")
}

// -------------------------------------------------------
// APP STATE (Singleton)
// Only 1 row with id = 1 (upsert pattern)
// -------------------------------------------------------
model AppState {
  id Int @id @default(1)

  active_dataset_id     String?
  active_dataset_name   String?
  active_dataset_type   String?
  active_dataset_source String?
  active_dataset_set_at DateTime?

  is_first_use Boolean  @default(true)
  updated_at   DateTime @updatedAt

  @@map("app_state")
}

// -------------------------------------------------------
// IMPORT BATCH
// -------------------------------------------------------
model ImportBatch {
  batch_id       String   @id
  batch_name     String
  source_dataset String // UCI | OULAD | CUSTOM
  learning_mode  String? // 'online' | 'offline' | 'hybrid'
  imported_at    DateTime
  is_active      Boolean  @default(false)
  is_sample      Boolean  @default(false)
  row_count      Int      @default(0)
  status         String // completed | failed | processing | seeded

  students               Student[]
  courses                Course[]
  classes                Class[]
  enrollments            Enrollment[]
  assessments            Assessment[]
  exam_results           ExamResult[]
  events                 Event[]
  engagements            Engagement[]
  enrollment_features    EnrollmentFeatures[]
  flat_enrollment_master FlatEnrollmentMaster[]
  flat_assessment_result FlatAssessmentResult[]

  @@map("import_batch")
}

// -------------------------------------------------------
// UPLOAD SESSION
// Stores import-wizard state so session survives backend restarts.
// -------------------------------------------------------
model UploadSession {
  session_id  String   @id
  payload     Json
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  expires_at  DateTime

  @@index([expires_at])
  @@map("upload_session")
}
