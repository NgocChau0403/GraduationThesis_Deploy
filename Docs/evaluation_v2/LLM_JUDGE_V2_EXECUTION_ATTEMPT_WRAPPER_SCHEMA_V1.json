{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "LLM_JUDGE_V2_EXECUTION_ATTEMPT_WRAPPER_SCHEMA_V1.json",
  "title": "LLM Judge V2 Execution Attempt Wrapper",
  "description": "Importer-generated provenance and validation wrapper for one judge record attempt.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evaluation_run_id",
    "record_id",
    "session_segment_id",
    "session_sequence_number",
    "attempt_number",
    "attempt_reason",
    "judge_status",
    "judge_input_sha256",
    "source_response_id",
    "source_response_message_index",
    "source_response_provider_id",
    "raw_or_source_response_path",
    "raw_or_source_response_sha256",
    "extracted_output_path",
    "validated_output_path",
    "validated_output_sha256",
    "validation_errors",
    "retrieval_log_path_if_applicable",
    "judged_at",
    "validated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "execution_attempt_wrapper_schema_v1"
    },
    "evaluation_run_id": {
      "type": "string",
      "minLength": 1
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "session_segment_id": {
      "type": "string",
      "minLength": 1
    },
    "session_sequence_number": {
      "type": "integer",
      "minimum": 1
    },
    "attempt_number": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3
    },
    "attempt_reason": {
      "enum": [
        "initial",
        "missing_or_truncated_output",
        "invalid_json",
        "schema_validation_failed",
        "semantic_validation_failed",
        "record_id_mismatch",
        "in_session_retrieval_failure",
        "other_technical_failure"
      ]
    },
    "judge_status": {
      "enum": [
        "raw_received",
        "valid",
        "retryable_invalid",
        "terminal_invalid"
      ]
    },
    "judge_input_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "source_response_id": {
      "type": "string",
      "minLength": 1
    },
    "source_response_message_index": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "source_response_provider_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "raw_or_source_response_path": {
      "type": "string",
      "minLength": 1
    },
    "raw_or_source_response_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "extracted_output_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "validated_output_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "validated_output_sha256": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[a-f0-9]{64}$"
    },
    "validation_errors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "retrieval_log_path_if_applicable": {
      "type": [
        "string",
        "null"
      ]
    },
    "judged_at": {
      "type": "string",
      "format": "date-time"
    },
    "validated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "judge_status": {
            "const": "valid"
          }
        },
        "required": [
          "judge_status"
        ]
      },
      "then": {
        "properties": {
          "validated_output_path": {
            "type": "string",
            "minLength": 1
          },
          "validated_output_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "validated_at": {
            "type": "string",
            "format": "date-time"
          },
          "validation_errors": {
            "maxItems": 0
          }
        }
      }
    }
  ]
}
