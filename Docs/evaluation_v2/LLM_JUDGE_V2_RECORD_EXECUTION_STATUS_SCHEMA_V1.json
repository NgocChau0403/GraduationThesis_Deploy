{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "LLM_JUDGE_V2_RECORD_EXECUTION_STATUS_SCHEMA_V1.json",
  "title": "LLM Judge V2 Record Execution Status",
  "description": "Run-coverage lifecycle state for one expected record. Attempt provenance is stored separately.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evaluation_run_id",
    "record_id",
    "record_status",
    "last_attempt_number",
    "exclusion_reason",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "record_execution_status_schema_v1"
    },
    "evaluation_run_id": {
      "type": "string",
      "minLength": 1
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "record_status": {
      "enum": [
        "pending",
        "in_progress",
        "raw_received",
        "valid",
        "retryable_invalid",
        "terminal_invalid",
        "excluded",
        "missing"
      ]
    },
    "last_attempt_number": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1,
      "maximum": 3
    },
    "exclusion_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "record_status": {
            "const": "excluded"
          }
        },
        "required": [
          "record_status"
        ]
      },
      "then": {
        "properties": {
          "exclusion_reason": {
            "type": "string",
            "minLength": 1
          },
          "last_attempt_number": {
            "const": null
          }
        }
      },
      "else": {
        "properties": {
          "exclusion_reason": {
            "const": null
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "record_status": {
            "enum": [
              "pending",
              "missing"
            ]
          }
        },
        "required": [
          "record_status"
        ]
      },
      "then": {
        "properties": {
          "last_attempt_number": {
            "const": null
          }
        }
      }
    }
  ]
}
